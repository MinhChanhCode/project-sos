{
	"info": {
		"_postman_id": "sos-restaurant-api",
		"name": "SOS Restaurant API",
		"description": "API collection cho hệ thống quản lý nhà hàng SOS",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "Menu Items",
			"item": [
				{
					"name": "Get All Menu Items",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/api/v1/menu-items",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "menu-items"]
						}
					}
				},
				{
					"name": "Get Active Menu Items",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/api/v1/menu-items/active",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "menu-items", "active"]
						}
					}
				},
				{
					"name": "Get Available Menu Items",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/api/v1/menu-items/available",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "menu-items", "available"]
						}
					}
				},
				{
					"name": "Get Menu Items by Category",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/api/v1/menu-items/category/{{category_id}}",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "menu-items", "category", "{{category_id}}"]
						}
					}
				},
				{
					"name": "Search Menu Items",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/api/v1/menu-items/search?keyword=phở",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "menu-items", "search"],
							"query": [
								{
									"key": "keyword",
									"value": "phở"
								}
							]
						}
					}
				},
				{
					"name": "Get Menu Item by ID",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/api/v1/menu-items/{{menu_item_id}}",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "menu-items", "{{menu_item_id}}"]
						}
					}
				},
				{
					"name": "Create Menu Item",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"name\": \"Phở bò đặc biệt\",\n  \"description\": \"Phở bò với đầy đủ thịt bò các loại\",\n  \"price\": 55000,\n  \"imageUrl\": \"https://example.com/pho-dac-biet.jpg\",\n  \"categoryId\": \"{{category_id}}\",\n  \"isAvailable\": true,\n  \"isActive\": true\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/v1/menu-items",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "menu-items"]
						}
					}
				},
				{
					"name": "Update Menu Item",
					"request": {
						"method": "PUT",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"name\": \"Phở bò đặc biệt (Cập nhật)\",\n  \"description\": \"Phở bò với đầy đủ thịt bò các loại - phiên bản mới\",\n  \"price\": 60000,\n  \"imageUrl\": \"https://example.com/pho-dac-biet-new.jpg\",\n  \"categoryId\": \"{{category_id}}\",\n  \"isAvailable\": true,\n  \"isActive\": true\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/v1/menu-items/{{menu_item_id}}",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "menu-items", "{{menu_item_id}}"]
						}
					}
				},
				{
					"name": "Delete Menu Item",
					"request": {
						"method": "DELETE",
						"header": [],
						"url": {
							"raw": "{{base_url}}/api/v1/menu-items/{{menu_item_id}}",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "menu-items", "{{menu_item_id}}"]
						}
					}
				},
				{
					"name": "Toggle Availability",
					"request": {
						"method": "PATCH",
						"header": [],
						"url": {
							"raw": "{{base_url}}/api/v1/menu-items/{{menu_item_id}}/toggle-availability",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "menu-items", "{{menu_item_id}}", "toggle-availability"]
						}
					}
				},
				{
					"name": "Toggle Active Status",
					"request": {
						"method": "PATCH",
						"header": [],
						"url": {
							"raw": "{{base_url}}/api/v1/menu-items/{{menu_item_id}}/toggle-active",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "menu-items", "{{menu_item_id}}", "toggle-active"]
						}
					}
				}
			]
		},
		{
